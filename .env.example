# Groq API Key (for AI chat - info)
# Get yours at: https://console.groq.com/
GROQ_API_KEY=gsk_xxxxx

# Shopify Storefront API (for checkout)
# Get from: Shopify Admin → Settings → Apps → Develop apps → Storefront API
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token

# Gelato Print-on-Demand API Key
# Get from: https://dashboard.gelato.com/ → Developer → API Keys
GELATO_API_KEY=your_gelato_key

# Admin API Key (required in production)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=your_admin_key

# Production flag (enables ADMIN_API_KEY enforcement)
NODE_ENV=development
